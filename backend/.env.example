# Django 기본 설정
SECRET_KEY=your-very-secret-key-here-change-in-production-make-it-very-long-and-random
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# 데이터베이스 설정 (프로덕션용 PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/prompthub
# DB_NAME=prompthub
# DB_USER=your_db_user  
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# 이메일 설정 (선택사항)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-email-password

# 미디어 파일 설정 (AWS S3 - 프로덕션용)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=ap-northeast-2

# Redis 설정 (캐싱/세션/Celery용)
# REDIS_URL=redis://localhost:6379/0

# CORS 설정
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Celery 설정 (백그라운드 작업용)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 로깅 레벨
LOG_LEVEL=INFO
